@page "/econ-cabinet"
@using MediatR
@* @rendermode InteractiveServer *@

@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<header>
    <NavCabinet />
</header>

<main>
    <SendForm DataForDownload="dataForDownload" TeamName="@TeamName" LastPeriod="@LastPeriod" showP1=@showP1 p1=@p1
              NextPeriod="@NextPeriod" />
    <MonitoringChart ChartData="realData" />
</main>

@code {
    private List<MonitoringChart.DataPoint> realData = new() { };
    private List<SendForm.DataPoint> dataForDownload = new() { };

    [Inject] public required IMediator Mediator { get; set; }
    [Inject] public required IIdentityService IdentityService { get; set; }
    [Inject] public required IEventCalendarService Calendar { get; set; }

    public Guid KeycloakId { get; set; }
    public List<Result>? ResultsList { get; set; }
    public class DataForChart
    {

        public string Period { get; set; } = "";
        public double CPI { get; set; }
        public double KeyRate { get; set; }

    }

    public string LastPeriod { get; set; } = "";
    public string NextPeriod { get; set; } = "";
    public string p1 { get; set; } = "";
    public bool showP1 { get; set; } = true;
    public string TeamName { get; set; } = "";
    protected override async Task OnInitializedAsync()
    {
        KeycloakId = await IdentityService.GetUserIdAsync();
        realData = await GetResults();
        TeamName = await IdentityService.GetUserNameAsync();
        dataForDownload = await GetResultsForDownload();



        // ✅ Используем MediatR для получения данных
        var queryAnswer = new GetAnswerQuery { TeamId = KeycloakId };
        var lastAnswer = await Mediator.Send(queryAnswer);
        var queryFile = new GetLastFileQuery { TeamId = KeycloakId };
        var lastFile = await Mediator.Send(queryFile);
        var currentDate = DateTime.UtcNow;
        var currentEvent = Calendar.GetEventTypeByDate(currentDate);

        bool hasTodayAnswer = lastAnswer?.IsTodayAnswer() ?? false;
        bool hasTodayFile = lastFile?.IsTodayFile() ?? false;

        showP1 = currentEvent switch
        {
            EventTypes.KeyRateSend => !hasTodayAnswer,
            EventTypes.KeyRateAndMetodologySend => !hasTodayAnswer,
            EventTypes.MetodologySend => !hasTodayFile,
            _ => false
        };

        if (dataForDownload != null && dataForDownload.Any())
        {
            LastPeriod = dataForDownload.Last().Period;
            NextPeriod = GetNextPeriod(LastPeriod);
        }
        else
        {
            LastPeriod = "241Q1";
            NextPeriod = GetNextPeriod(LastPeriod);
        }

        p1 = currentEvent switch
        {
            EventTypes.KeyRateSend =>
                $"1. Отправить ключевую ставку за {NextPeriod}",
            EventTypes.KeyRateAndMetodologySend =>
                $"1. Отправить ключевую ставку за {NextPeriod}\n2. Отправить обзор ДКП",
            EventTypes.MetodologySend =>
                $"1. Отправить методологию",
            _ => ""
        };
    }

    public class Answer
    {
        public Guid Id { get; set; }
        public Guid TeamId { get; set; }
        public DateTime CreatedAt { get; set; }
        public DateTime CreatedDate { get; set; }
        public double AnswerValue { get; set; }
        public int NullCount { get; set; } = 0;
    }

    public class LoadedFile

    {
        public Guid Id { get; set; }
        public Guid TeamId { get; set; } // FOREIGN KEY → Team.Id
        public string Name { get; set; } = "";
        public string Path { get; set; } = "";
        public string ContentType { get; set; } = ""; // pdf, csv, rar etc.
        public long FileSize { get; set; } // размер в байтах
        public DateTime CreatedAt { get; set; }
        public DateTime CreatedDate { get; set; }
    }

    public class Result

    {
        public Guid Id { get; set; }
        public string Period { get; set; } = "";
        public double NominalExchangeRate { get; set; }
        public double CPI { get; set; }
        public double RealExchangeRate { get; set; }
        public double RealGDP { get; set; }
        public double KeyRate { get; set; }
        public DateTime CreatedAt { get; set; }
        public Guid? AnswerId { get; set; }

    }

    public async Task<List<MonitoringChart.DataPoint>> GetResults()
    {

        var query2 = new GetResultsQuery()
        {
            TeamId = KeycloakId,
        };
        var domainResults = await Mediator.Send(query2);

    
        // Маппинг Domain.Result -> MonitoringChart.DataPoint
        var dataPoints = domainResults.Select(r => new MonitoringChart.DataPoint
        {
            Period = r.Period, // предположим, у Domain.Result есть свойство Period
            KeyRate = r.KeyRate, // и KeyRate
            Inflation = r.CPI, // и Inflation
            Target = 4 // и Target
        }).ToList();

        return dataPoints;
    }


    public string GetNextPeriod(string currentPeriod)
    {
        // Защита от null и пустых строк
        if (string.IsNullOrWhiteSpace(currentPeriod))
            return "Нет данных";

        // Разделяем строку по 'Q'
        var parts = currentPeriod.Split('Q');

        // Проверяем, что строка имеет формат "254Q4"
        if (parts.Length != 2)
            return currentPeriod;

        // Парсим год и квартал
        if (!int.TryParse(parts[0].Trim(), out int year))
            return currentPeriod;

        if (!int.TryParse(parts[1].Trim(), out int quarter))
            return currentPeriod;

        // Проверяем допустимость квартала (1-4)
        if (quarter < 1 || quarter > 4)
            return currentPeriod;

        // ✅ Увеличиваем квартал
        quarter++;

        // ✅ Если был 4-й квартал, переходим на следующий год
        if (quarter > 4)
        {
            quarter = 1;
            year++;
        }

        return $"{year}Q{quarter}";
    }

    public async Task<List<SendForm.DataPoint>> GetResultsForDownload()
    {

        var query2 = new GetResultsQuery()
        {
            TeamId = KeycloakId,
        };
        var domainResults = await Mediator.Send(query2);


        var dataPoints = domainResults.Select(r => new SendForm.DataPoint
        {
            Period = r.Period,
            NominalExchangeRate = r.NominalExchangeRate,
            CPI = r.CPI,
            RealExchangeRate = r.RealExchangeRate,
            RealGDP = r.RealGDP,
            KeyRate = r.KeyRate
        }).ToList();

        return dataPoints;
    }

    
}
