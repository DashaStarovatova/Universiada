@using System.IO
@using Application.Commands
@using Application.Models
@using MediatR
@using Microsoft.AspNetCore.Components.Forms
@using Web.Components.Components
@inject IJSRuntime JSRuntime
@using System.Text

@rendermode InteractiveServer


<div class="form-total">

    <div class="teamName">
        <p>Личный кабинет команды @TeamName</p>
    </div>

    <div class="form-card">
        <div class="left-card">

            <div class="today-task">
                <p class="task-title">Задачи на сегодня</p>
                <p style="white-space: pre-line; padding-left: 1rem;" class="@(@showP1 ? "p1" : "hidden")">@p1</p>
                <p style="white-space: pre-line; padding-left: 1rem;" class="@(@showP2 ? "p2" : "hidden")">@p2</p>
            </div>

            <div class="reference-information">
                <p>
                    Отправка доступна с 00:00 до 18:00 МСК согласно
                    <a href="downloads/calendar.pdf" download="Календарь_олимпиады.pdf" class="calendar-link">
                        календарю олимпиады.
                    </a>
                </p>
                <span class="divider"></span>
                <p>Отправить форму ответа можно 1 раз в день. Обзор ДКП отправляется одновременно со ставкой.</p>
                <span class="divider"></span>
                <p>Для просмотра новых данных зайдите в личный кабинет через 10 минут после отправки ключевой ставки.
                </p>
                <span class="divider"></span>
                <p>Если вы не отправите ставку в указанный период, то будет использовано ваше предыдущее решение.
                    Пропустить отправку ставки можно не более 2 раз подряд, иначе команда будет дисквалифицирована.</p>
                </div>

            </div>

            

            <EditForm class="right-card" Model="@Model" OnSubmit="@SendFormAnswer" FormName="sendForm">
                <div class="right-card-wrapper">
                    <div class="send-form">
                        <p class="title">Отправить решение по ставке</p>
                        <p class="subtitle">Введите ключевую ставку за @NextPeriod (в %)</p>

                        <div class="form-field">
                            <InputNumber type="text" class="field-input" placeholder="Например: 7.25"
                                         @bind-Value="@Model.KeyRate" disabled="@IsDisabledKeyRate" />
                        </div>

                        <span class="divider"></span>

                        <p class="title">Загрузить обзор ДКП / Методологию</p>
                        <p class="subtitle">Загрузка файлов доступна согласно календарю</p>

                        <div class="form-field">
                            <InputFile type="file" id="fileInput" class="custom-file-input" OnChange="HandleFileSelected"
                                       accept=".pdf" disabled="@IsDisabledFile" />
                        </div>
                    </div>

        
                    <div class="form-action">
                        <button type="button" @onclick="DownloadCsv" class="download-button">
                            Скачать данные за @LastPeriod
                            <span class="download-btn-dot"></span>
                        </button>

                        <button type="submit" class="send-button">
                            Отправить
                            <span class="btn-dot"></span>
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

@code {
    [Inject] public required IMediator Mediator { get; set; }
    [Inject] public required IIdentityService IdentityService { get; set; }
    [Inject] public required IEventCalendarService Calendar { get; set; }
    [Inject] public required ILogger<SendForm> Logger { get; set; }
    [Parameter] public string TeamName { get; set; } = "";
    [Parameter] public bool showP1 { get; set; }
    [Parameter] public string p1 { get; set; }
    [Parameter] public string LastPeriod { get; set; } = "";
    [Parameter] public string NextPeriod { get; set; } = "";

    public bool showP2 => !@showP1;
    public string p2 { get; set; } = "отсутствуют";

    public class DataPoint
    {
        public string Period { get; set; } = "";
        public double NominalExchangeRate { get; set; }
        public double CPI { get; set; }
        public double RealExchangeRate { get; set; }
        public double RealGDP { get; set; }
        public double KeyRate { get; set; }
    }

    private string? selectedFileName;
    private string errorMessage = "";
    private byte[]? selectedPdfBytes;
    private string selectedFileExtension = "";
    private long fileSizeInKB;
    private const long MAX_FILE_SIZE = 20 * 1024 * 1024; // 20 MB

    public Guid KeycloakId { get; set; }
    public string KeycloakName { get; set; }
    public InputModel Model { get; set; } = new();

    private string LastPeriod1 { get; set; } = "";
    private string NextPeriod1 { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        KeycloakId = await IdentityService.GetUserIdAsync();
        KeycloakName = await IdentityService.GetUserNameAsync();



        if (DataForDownload != null && DataForDownload.Any())
        {
            LastPeriod1 = DataForDownload.Last().Period;
            NextPeriod1 = GetNextPeriod(LastPeriod);
        }
        else
        {
            LastPeriod1 = "";
        }
    }


    public string GetNextPeriod(string currentPeriod)
    {
        // Защита от null и пустых строк
        if (string.IsNullOrWhiteSpace(currentPeriod))
            return "Нет данных";

        // Разделяем строку по 'Q'
        var parts = currentPeriod.Split('Q');

        // Проверяем, что строка имеет формат "254Q4"
        if (parts.Length != 2)
            return currentPeriod;

        // Парсим год и квартал
        if (!int.TryParse(parts[0].Trim(), out int year))
            return currentPeriod;

        if (!int.TryParse(parts[1].Trim(), out int quarter))
            return currentPeriod;

        // Проверяем допустимость квартала (1-4)
        if (quarter < 1 || quarter > 4)
            return currentPeriod;

        // ✅ Увеличиваем квартал
        quarter++;

        // ✅ Если был 4-й квартал, переходим на следующий год
        if (quarter > 4)
        {
            quarter = 1;
            year++;
        }

        return $"{year}Q{quarter}";
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = "";

        if (e.File != null)
        {

            selectedFileExtension = Path.GetExtension(e.File.Name).ToLower();

            // Проверка расширения
            if (selectedFileExtension != ".pdf")
            {
                errorMessage = "Ошибка: разрешены только PDF файлы!";
                selectedPdfBytes = null;
                return;
            }

            // Проверка размера
            if (e.File.Size > MAX_FILE_SIZE)
            {
                errorMessage = $"Ошибка: файл слишком большой (максимум 20 MB). Ваш файл: {e.File.Size / 1024 / 1024} MB";
                selectedPdfBytes = null;
                return;
            }

            // Получаем имя и размер
            selectedFileName = e.File.Name;
            fileSizeInKB = e.File.Size / 1024;

            using var stream = e.File.OpenReadStream(MAX_FILE_SIZE);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            selectedPdfBytes = memoryStream.ToArray();

            // Проверка, что прочитали правильное количество байт
            if (selectedPdfBytes.Length != e.File.Size)
            {
                errorMessage = $"Ошибка чтения файла";
                selectedPdfBytes = null;
                return;
            }

            // Сохраняем в модель
            Model.FileContent = selectedPdfBytes;
            Model.Name = selectedFileName;
            Model.FileSize = fileSizeInKB;

            StateHasChanged(); // обязательно, вручную обновляет экран
        }
    }

    public async Task SendFormAnswer()
    {

        try
        {
            var currentDate = DateTime.UtcNow;
            var currentEvent = Calendar.GetEventTypeByDate(currentDate);

            IRequest<ResultBase> command = currentEvent switch
            {
                EventTypes.KeyRateSend => new SendKeyRateCommand()
                {
                    TeamId = KeycloakId,
                    KeyRate = Model.KeyRate,
                    IsNul = false
                },
                EventTypes.KeyRateAndMetodologySend => new SendKeyRateAndMetodologyCommand()
                {
                    TeamId = KeycloakId,
                    KeyRate = Model.KeyRate,
                    FileName = Model.Name,
                    FileData = Model.FileContent,
                    IsNul = false
                },
                EventTypes.MetodologySend => new SendMetodologyCommand()
                {
                    TeamId = KeycloakId,
                    FileName = Model.Name,
                    FileData = Model.FileContent
                },
                _ => null
            };

            if (command == null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Следующая отправка будет доступна согласно календарю мероприятия.");
                Logger.LogInformation("Событие {EventType} не поддерживается, форма не отправлена", currentEvent);
                return; // ← Тихо выходим, без ошибки
            }

            var response = await Mediator.Send(command);

            if (response is FailResult failResult)
            {
                // Показываем сообщение пользователю
                await JSRuntime.InvokeVoidAsync("alert", "Вы уже отвечали сегодня. Следующая отправка согласно календарю мероприятия.");
                Logger.LogInformation("Попытка повторной отправки: {Message}", failResult.Description);
                return; // Выходим, не сбрасывая форму
            }

            await JSRuntime.InvokeVoidAsync("alert", "Ваш ответ принят! Повторно отправить форму нельзя. Следующая отправка согласно календарю мероприятия.");

            Logger.LogInformation("Форма успешно отправлена");

            // Сброс формы после успешной отправки
            Model = new InputModel();
            selectedFileName = null;
            selectedPdfBytes = null;
            errorMessage = "";

        }
        catch (Exception ex)
        {
            errorMessage = "Произошла ошибка при отправке данных: " + ex.Message;
            Logger.LogError(ex, "Ошибка при отправке формы");
            await JSRuntime.InvokeVoidAsync("alert", "При отправке ответа произошла ошибка. Повторите попытку позднее. Если в течение дня ошибка не исчезнет обратитесь к организаторам.");
        }
        finally
        {
            StateHasChanged();
        }
    }

    public class InputModel
    {
        public float KeyRate { get; set; }
        public byte[] FileContent { get; set; } = new byte[0];
        public string Name { get; set; } = "";
        public string ContentType { get; set; } = "pdf";
        public long FileSize { get; set; }
        public string FilePath { get; set; } = "c:\\Users\\Darya\\Desktop\\Работа\\Универсиада\\letsgo";
    }


    private bool IsDisabledKeyRate => !IsSubmitAvailableKeyRate();

    private bool IsSubmitAvailableKeyRate()
    {
        // Получаем текущее время по Москве (UTC+3)
        var moscowTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Russian Standard Time");
        var currentMoscowTime = TimeZoneInfo.ConvertTime(DateTime.UtcNow, moscowTimeZone);

        // Проверка: с 18:01 до 23:59 по Москве
        var timeOfDay = currentMoscowTime.TimeOfDay;
        var startNight = new TimeSpan(18, 1, 0); // 18:01
        var endNight = new TimeSpan(0, 0, 0); // 00:00

        bool isNightTime = timeOfDay >= startNight || timeOfDay < endNight;

        if (isNightTime)
            return false;

        // Проверка события
        var currentEvent = Calendar.GetEventTypeByDate(DateTime.UtcNow);

        return currentEvent switch
        {
            EventTypes.KeyRateSend => true,
            EventTypes.KeyRateAndMetodologySend => true,
            EventTypes.MetodologySend => false,
            _ => false
        };
    }

    private bool IsDisabledFile => !IsSubmitAvailableFile();

    private bool IsSubmitAvailableFile()
    {
        // Получаем текущее время по Москве (UTC+3)
        var moscowTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Russian Standard Time");
        var currentMoscowTime = TimeZoneInfo.ConvertTime(DateTime.UtcNow, moscowTimeZone);

        // Проверка: с 18:01 до 08:59 по Москве
        var timeOfDay = currentMoscowTime.TimeOfDay;
        var startNight = new TimeSpan(18, 1, 0); // 18:01
        var endNight = new TimeSpan(9, 0, 0); // 09:00

        bool isNightTime = timeOfDay >= startNight || timeOfDay < endNight;

        if (isNightTime)
            return false;

        // Проверка события
        var currentEvent = Calendar.GetEventTypeByDate(DateTime.UtcNow);

        return currentEvent switch
        {
            EventTypes.KeyRateSend => false,
            EventTypes.KeyRateAndMetodologySend => true,
            EventTypes.MetodologySend => true,
            _ => false
        };
    }




    [Parameter] public List<DataPoint> DataForDownload { get; set; } = new();

    private async Task DownloadCsv()

    {
        // 1. Генерируем CSV строку
        var csvContent = GenerateCsvString(DataForDownload);

        // 2. Получаем последний период для скачивания
        var lastPeriod = LastPeriod;

        // 3. Передаём в JS для скачивания
        var fileName = $"data_{lastPeriod}.csv";
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, csvContent);
    }




    private string GenerateCsvString(List<DataPoint> data)
    {
        var sb = new StringBuilder();
        @* sb.AppendLine("sep=,"); *@
        sb.AppendLine("Период, Номинальный курс кв/кв ln(x/100), Индекс потребительских цен кв/кв ln(x/100), Реальный курс кв/кв ln(x/100), Реальный выпуск кв/кв ln(x/100), Ключевая ставка %"); sb.AppendLine("period, zzobs_dNFX,zzobs_dPC,zzobs_dRFX, zzobs_dY, zzobs_r_G");

        // ⭐ Загружаем исторические данные из CSV
        var csvPath = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot/downloads", "historical_data.csv");
        if (File.Exists(csvPath))
        {
            var historicalData = LoadDataFromCsv(csvPath);
            foreach (var item in historicalData)
            {
                // ✅ Принудительно преобразуем числа с точкой
                var period = EscapeCsvField(item.Period);
                var nominal = item.NominalExchangeRate.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var cpi = item.CPI.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var real = item.RealExchangeRate.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var gdp = item.RealGDP.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var rate = item.KeyRate.ToString(System.Globalization.CultureInfo.InvariantCulture);

                sb.AppendLine($"{period},{nominal},{cpi},{real},{gdp},{rate}");
            }
        }

        // Добавляем актуальные данные
        if (data != null && data.Any())
        {
            foreach (var item in data)
            {
                var period = EscapeCsvField(item.Period);
                var zzobs_dNFX = item.NominalExchangeRate.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var zzobs_dPC = item.CPI.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var zzobs_dRFX = item.RealExchangeRate.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var zzobs_dY = item.RealGDP.ToString(System.Globalization.CultureInfo.InvariantCulture);
                var zzobs_r_G = item.KeyRate.ToString(System.Globalization.CultureInfo.InvariantCulture);

                sb.AppendLine($"{period},{zzobs_dNFX},{zzobs_dPC},{zzobs_dRFX},{zzobs_dY},{zzobs_r_G}");
            }
        }

        return sb.ToString();
    }



    private List<DataPoint> LoadDataFromCsv(string filePath)
    {
        var data = new List<DataPoint>();

        using (var reader = new StreamReader(filePath))
        {
            // Пропускаем заголовки (если они есть)
            var header = reader.ReadLine();

            // Читаем строки
            while (!reader.EndOfStream)
            {
                var line = reader.ReadLine();
                if (string.IsNullOrWhiteSpace(line))
                    continue;

                // Разбиваем по запятой
                var values = line.Split(',');

                // Проверяем, что колонок достаточно (6 штук)
                if (values.Length >= 6)
                {
                    var dataPoint = new DataPoint
                    {
                        Period = values[0].Trim(),
                        NominalExchangeRate = ParseDouble(values[1]),
                        CPI = ParseDouble(values[2]),
                        RealExchangeRate = ParseDouble(values[3]),
                        RealGDP = ParseDouble(values[4]),
                        KeyRate = ParseDouble(values[5])
                    };
                    data.Add(dataPoint);
                }
            }
        }

        return data;
    }


    private double ParseDouble(string value)
    {
        return double.TryParse(value?.Replace(",", "."),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture,
            out double result) ? result : 0;
    }

    private string EscapeCsvField(string field)
    {
        if (string.IsNullOrEmpty(field))
            return string.Empty;

        // Если поле содержит запятую, кавычку или перевод строки - оборачиваем в кавычки
        if (field.Contains(",") || field.Contains("\"") || field.Contains("\n"))
        {
            // Дублируем кавычки внутри поля
            var escaped = field.Replace("\"", "\"\"");
            return $"\"{escaped}\"";
        }

        return field;
    }



}